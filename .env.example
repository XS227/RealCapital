# ── Data source ────────────────────────────────────────────────────────────────
# Absolute path to the trading agent's memory.json (read-only)
MEMORY_JSON_PATH=/home/ubuntu/ton-momentum-hunter/memory.json

# Set to 0 to force mock data (useful for UI dev without a live agent)
LIVE_DATA=1

# ── Admin auth ────────────────────────────────────────────────────────────────
# Bcrypt hash of the admin password. Generate with:
#   node -e "const b=require('crypto');console.log(b.createHash('sha256').update('yourpassword').digest('hex'))"
# Or use bcrypt: npx bcrypt-cli hash yourpassword 12
ADMIN_PASSWORD_HASH=<bcrypt_hash_here>

# Secret for iron-session cookie encryption (32+ random chars)
SESSION_SECRET=change_me_to_32_random_chars_minimum_please

# ── App ───────────────────────────────────────────────────────────────────────
# Public hostname (used for OG meta, no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:4012
