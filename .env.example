# ── Data source (read-only) ───────────────────────────────────────────────────
# Absolute path to the trading agent's memory.json. Never write to this file.
MEMORY_JSON_PATH=/home/ubuntu/ton-momentum-hunter/memory.json

# Set to 0 to force mock data (useful for UI development without a live agent)
LIVE_DATA=1

# ── Admin authentication ──────────────────────────────────────────────────────
# SHA-256 hex hash of your admin password.
# Generate a new one:
#   node -e "const c=require('crypto'); console.log(c.createHash('sha256').update('YOUR_STRONG_PASSWORD').digest('hex'))"
# Never commit the plaintext password. Only this hash goes here.
ADMIN_PASSWORD_HASH=

# Iron-session encryption secret. Must be at least 32 random characters.
# Generate a new one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotate this value if you suspect it has been compromised.
SESSION_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
# Public-facing hostname, no trailing slash (used in meta tags)
NEXT_PUBLIC_APP_URL=https://realcapital.no
